#!/usr/bin/env bash
# safe-claude — lanza Claude Code dentro de un sandbox bubblewrap
# Uso: safe-claude [args...]

set -euo pipefail

if ! command -v bwrap >/dev/null 2>&1; then
  echo "error: bubblewrap (bwrap) no está instalado" >&2
  echo "instala con: sudo dnf install -y bubblewrap / sudo apt install -y bubblewrap" >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "error: claude no está instalado" >&2
  exit 1
fi

bwrap_args=(
  --ro-bind /usr /usr
  --dev /dev
  --tmpfs /tmp
  --proc /proc
  --ro-bind /etc/resolv.conf /etc/resolv.conf
  --bind "$PWD" "$PWD"
  --unshare-net-priv
  --die-with-parent
  --new-session
)

for lib_dir in /lib /lib64 /usr/lib64 /usr/lib/x86_64-linux-gnu /usr/lib/aarch64-linux-gnu; do
  if [ -d "$lib_dir" ]; then
    bwrap_args+=(--ro-bind "$lib_dir" "$lib_dir")
  fi
done

exec bwrap "${bwrap_args[@]}" claude "$@"
