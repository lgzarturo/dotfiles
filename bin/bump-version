#!/usr/bin/env bash
# bump-version — incrementa versión semver, commitea y crea git tag
# Uso: bump-version <major|minor|patch>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION_FILE="$REPO_ROOT/VERSION"

if [ ! -f "$VERSION_FILE" ]; then
  echo "error: no se encontró $VERSION_FILE" >&2
  exit 1
fi

bump="${1:?uso: bump-version <major|minor|patch>}"

current="$(tr -d '[:space:]' < "$VERSION_FILE")"

IFS='.' read -r major minor patch <<< "$current"

case "$bump" in
  major)
    major=$((major + 1))
    minor=0
    patch=0
    ;;
  minor)
    minor=$((minor + 1))
    patch=0
    ;;
  patch)
    patch=$((patch + 1))
    ;;
  *)
    echo "error: argumento inválido '$bump'. Usar: major, minor o patch" >&2
    exit 1
    ;;
esac

new_version="${major}.${minor}.${patch}"

echo "$new_version" > "$VERSION_FILE"

echo "versión: $current → $new_version"

cd "$REPO_ROOT"
git add "$VERSION_FILE"
git commit -m "chore(release): v${new_version}"
git tag "v${new_version}"

echo "✓ commit y tag v${new_version} creados"
echo "  para publicar: git push && git push --tags"
