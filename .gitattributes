# .gitattributes — normalización de line endings por tipo de archivo
# Garantiza LF en scripts Unix y CRLF en scripts Windows.

# Detección automática para archivos no listados explícitamente
* text=auto

# Scripts bash/sh: siempre LF (WSL, Linux, macOS)
*.sh    text eol=lf
.envrc  text eol=lf

# Scripts PowerShell: CRLF en Windows checkout
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf

# Archivos de texto/config: LF
*.md    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.conf  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.env   text eol=lf
Makefile text eol=lf

# Binarios: sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.tar   binary
*.gz    binary
