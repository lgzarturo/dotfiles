{
  "$schema": "https://json.schemastore.org/prettierrc",

  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "none",
  "endOfLine": "lf",

  "overrides": [
    {
      "files": ["*.md"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always"
      }
    },
    {
      "files": ["*.ps1"],
      "options": {
        "endOfLine": "crlf"
      }
    },
    {
      "files": ["*.toml"],
      "options": {
        "printWidth": 80
      }
    }
  ]
}
