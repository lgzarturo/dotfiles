root = true

# ─── Defaults globales ───────────────────────────────────────────────────────
[*]
charset               = utf-8
end_of_line           = lf
indent_style          = space
indent_size           = 2
trim_trailing_whitespace = true
insert_final_newline  = true

# ─── Shell scripts ───────────────────────────────────────────────────────────
[*.sh]
indent_size = 2

# ─── PowerShell ──────────────────────────────────────────────────────────────
[*.ps1]
indent_size         = 4
end_of_line         = crlf

# ─── TOML ────────────────────────────────────────────────────────────────────
[*.toml]
indent_size = 2

# ─── Markdown ────────────────────────────────────────────────────────────────
[*.md]
max_line_length          = 80
trim_trailing_whitespace = false  # trailing spaces = <br> en Markdown

# ─── YAML ────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─── JSON / JSONC ────────────────────────────────────────────────────────────
[*.{json,jsonc}]
indent_size = 2

# ─── Git config ──────────────────────────────────────────────────────────────
[.gitconfig]
indent_style = tab
